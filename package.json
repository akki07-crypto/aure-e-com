{
  "name": "aura-ecommerce",
  "version": "1.0.0",
  "description": "AURA - Premium Smart Devices & Lifestyle Electronics E-Commerce Website",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "node --watch server.js",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && npm install --prefix client",
    "build-all": "npm run build --prefix client"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.1.1",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1"
  }
}
